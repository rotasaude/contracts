{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rota-saude/schemas/protocol-definition.json",
  "title": "Protocol Definition",
  "description": "Contrato compartilhado por motor Ruby (ADR-0013) e preview TS (ADR-0016).",
  "type": "object",
  "required": ["name", "version", "start_step_id", "steps"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]+$",
      "description": "Identificador estável do protocolo, ex.: triagem-respiratoria"
    },
    "version": { "type": "integer", "minimum": 1 },
    "schema_version": { "type": "integer", "minimum": 1, "default": 1 },
    "start_step_id": { "type": "string" },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/step" }
    },
    "scoring": {
      "oneOf": [
        { "$ref": "#/$defs/scoring_weighted" },
        { "$ref": "#/$defs/scoring_decision_table" }
      ]
    }
  },
  "$defs": {
    "step": {
      "type": "object",
      "required": ["id", "prompt", "answer_type"],
      "additionalProperties": false,
      "properties": {
        "id":          { "type": "string" },
        "prompt":      { "type": "string" },
        "answer_type": { "enum": ["boolean", "enum", "integer", "text"] },
        "options": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Obrigatório quando answer_type=enum"
        },
        "branches": {
          "type": "object",
          "additionalProperties": {
            "oneOf": [
              { "type": "string" },
              { "type": "null" }
            ]
          },
          "description": "answer_value -> next_step_id (null = terminal)"
        },
        "weights": {
          "type": "object",
          "additionalProperties": { "type": "integer" },
          "description": "answer_value -> peso numérico (usado por scoring weighted)"
        }
      }
    },
    "scoring_weighted": {
      "type": "object",
      "required": ["type", "thresholds"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "weighted" },
        "thresholds": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "type": "integer" }
        },
        "priority_map": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 1, "maximum": 9 }
        }
      }
    },
    "scoring_decision_table": {
      "type": "object",
      "required": ["type", "rules"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "decision_table" },
        "rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["when", "tier", "priority"],
            "additionalProperties": false,
            "properties": {
              "when":     { "type": "object", "additionalProperties": { "type": "string" } },
              "tier":     { "type": "string" },
              "priority": { "type": "integer", "minimum": 1, "maximum": 9 }
            }
          }
        },
        "fallback": {
          "type": "object",
          "required": ["tier", "priority"],
          "additionalProperties": false,
          "properties": {
            "tier":     { "type": "string" },
            "priority": { "type": "integer", "minimum": 1, "maximum": 9 }
          }
        }
      }
    }
  }
}
